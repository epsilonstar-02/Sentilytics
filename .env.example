# Environment Variables Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# Google/Gemini API Configuration (Required for AI Agents)
# =============================================================================
GOOGLE_API_KEY=your_google_gemini_api_key_here
YOUTUBE_API_KEY=your_youtube_api_key_here

# =============================================================================
# PostgreSQL Database Configuration (Required for Data Storage)
# =============================================================================
# Database connection settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=youtube_analytics
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# =============================================================================
# Application Configuration (Optional)
# =============================================================================
# Set to 'development' or 'production'
APP_ENV=development

# Dashboard port (default: 8050)
DASHBOARD_PORT=8050

# Enable debug mode (True/False)
DEBUG_MODE=False

# =============================================================================
# Setup Instructions
# =============================================================================
# 
# 1. Google API Key:
#    - Go to: https://makersuite.google.com/app/apikey
#    - Create a new API key for Gemini
#    - Copy and paste above
#
# 2. YouTube API Key:
#    - Go to: https://console.cloud.google.com/
#    - Enable YouTube Data API v3
#    - Create credentials → API Key
#    - Copy and paste above
#
# 3. PostgreSQL Setup:
#    - Install PostgreSQL: brew install postgresql@15 (macOS)
#    - Start service: brew services start postgresql@15
#    - Create database: createdb youtube_analytics
#    - Set your password above
#
# 4. Verify Configuration:
#    - Run: python database/db_config.py
#    - Should see: "✅ Database connection successful!"
#
# =============================================================================
